{
  "name": "indexer",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "crank": "tsx src/crank.ts",
    "backfill": "tsx src/backfill.ts",
    "build": "npm run prisma:generate && tsc",
    "prestart": "npx prisma migrate deploy && npm run migrate:status",
    "start": "node dist/index.js",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "migrate:status": "npx prisma migrate status",
    "test": "vitest run",
    "lint": "npm run prisma:generate && tsc --noEmit",
    "postinstall": "npx prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@stellar/stellar-sdk": "^14.6.1",
    "@types/express-rate-limit": "^5.1.3",
    "axios": "^1.15.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "prom-client": "15.1.3",
    "redis": "^4.6.15"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/node": "^20.14.2",
    "@types/supertest": "^6.0.2",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "path-to-regexp": "^8.4.0"
  }
}
