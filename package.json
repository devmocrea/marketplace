{
  "name": "marketplace",
  "version": "1.0.0",
  "description": "> Decentralized marketplace for African art, built on Stellar + Soroban smart contracts.",
  "main": "index.js",
  "workspaces": [
    "frontend/afristore-app",
    "indexer"
  ],
  "scripts": {
    "dev": "concurrently \"npm --workspace=indexer run dev\" \"npm --workspace=frontend/afristore-app run dev\" \"npm --workspace=indexer run crank\"",
    "build:contracts": "cargo build --target wasm32v1-none --release --manifest-path contracts/soroban-marketplace/Cargo.toml",
    "test:contracts": "cargo test --manifest-path contracts/soroban-marketplace/Cargo.toml",
    "deploy:local": "bash scripts/deploy/deploy_contract.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.3"
  },
  "overrides": {
    "next": {
      "postcss": ">=8.5.10"
    },
    "glob": "^10.4.5",
    "minimatch": "^9.0.5",
    "form-data": "^4.0.1"
  }
}
